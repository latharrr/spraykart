# ─── Database ─────────────────────────────────────────────────────────────────
# Local: postgresql://postgres:password@127.0.0.1:5432/spraykart
# Supabase: get from Dashboard → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars
CRON_SECRET=your-secure-cron-secret-at-least-32-chars

# ─── Error Monitoring (Sentry) ────────────────────────────────────────────────
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Use rzp_test_ keys for development, rzp_live_ for production
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Paytm ────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.paytm.com → Developers → API Keys
PAYTM_MID=your_paytm_merchant_id
PAYTM_MERCHANT_KEY=your_paytm_merchant_key
PAYTM_CALLBACK_URL=https://yourdomain.com/api/payments/paytm/callback
# Stage: https://securegw-stage.paytm.in | Production: https://securegw.paytm.in
PAYTM_HOST=https://securegw-stage.paytm.in

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Spraykart <orders@spraykart.in>
ADMIN_EMAIL=admin@spraykart.in

# ─── Redis Cache — OPTIONAL ───────────────────────────────────────────────────
# Leave blank to use in-process LRU cache (site still works, just no shared cache)
# Self-hosted Redis:
REDIS_URL=redis://127.0.0.1:6379
# Upstash serverless Redis (alternative to REDIS_URL):
# UPSTASH_REDIS_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_TOKEN=your_redis_token

# ─── Site URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://spraykart.deepanshulathar.dev

# ─── Business / Legal ─────────────────────────────────────────────────────────
# Shown on policy pages, invoices, and contact page
NEXT_PUBLIC_BUSINESS_NAME=Spraykart
BUSINESS_LEGAL_NAME=Spraykart [Legal Entity Name]
BUSINESS_ADDRESS=[Registered business address, India]
NEXT_PUBLIC_BUSINESS_ADDRESS=[Registered business address, India]
BUSINESS_EMAIL=support@spraykart.in
NEXT_PUBLIC_BUSINESS_EMAIL=support@spraykart.in
BUSINESS_PHONE=[Business phone number]
NEXT_PUBLIC_BUSINESS_PHONE=[Business phone number]
BUSINESS_GSTIN=[GSTIN]
BUSINESS_STATE=Delhi
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=999
NEXT_PUBLIC_STANDARD_SHIPPING_FEE=49
