# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars_long_change_this

# ─── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
# Generate from: Razorpay Dashboard → Webhooks → Add Webhook → copy secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Email (Nodemailer via Gmail App Password) ─────────────────────────────────
# PRODUCTION: Replace with Resend (resend.com) for better deliverability
# Gmail setup: myaccount.google.com → Security → 2-Step Verification → App passwords
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_16_char_app_password
ADMIN_EMAIL=admin@yourstore.com

# ─── Redis / Caching (Upstash — free tier) ─────────────────────────────────────
# Optional for development. Get from: console.upstash.com
UPSTASH_REDIS_URL=https://xxx.upstash.io
UPSTASH_REDIS_TOKEN=your_upstash_token

# ─── App ───────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
